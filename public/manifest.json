{
  "manifest_version": 3,
  "name": "JS Timer",
  "version": "1.0.0",
  "description": "Simple countdown timer Chrome extension",
  "permissions": ["alarms", "storage", "notifications", "sidePanel"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
